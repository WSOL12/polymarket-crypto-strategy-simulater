PORT=3000
# Browser WebSocket (separate from Express — avoids upgrade bugs with same port)
WS_PORT=3001
SYMBOL=BTC
HORIZONS=15m

# REQUIRED: set the Polymarket series slug for each horizon you enable.
# Example values are placeholders; replace with real slugs from Polymarket.
SERIES_SLUG__15M=REPLACE_WITH_REAL_15M_SERIES_SLUG
# SERIES_SLUG__5M=REPLACE_WITH_REAL_5M_SERIES_SLUG
# SERIES_SLUG__1H=REPLACE_WITH_REAL_1H_SERIES_SLUG

# Optional
POLL_MS=5000
OUTPUT_DIR=./data
GAMMA_BASE_URL=https://gamma-api.polymarket.com
DATA_API_BASE_URL=https://data-api.polymarket.com
SCREENSHOT_FORMAT=png

# Polymarket Real-Time Data Socket (Binance spot index for header prices). Up/Down books use CLOB separately.
# https://docs.polymarket.com/market-data/websocket/rtds
RTDS_URL=wss://ws-live-data.polymarket.com

# Optional: if Gamma/collector has not stored a window yet, paste outcome token IDs from Polymarket
# (CLOB / market details) so the backend can subscribe to Up/Down without SQLite rows.
# MANUAL_CLOB_WINDOW_SLUG=btc-updown-15m-manual
# MANUAL_UP_TOKEN_ID=
# MANUAL_DOWN_TOKEN_ID=
